flowchart TD
    BUYER([Buyer])
    SELLER([Seller])
    DB[(Supabase PostgreSQL)]
    STORAGE[(Supabase Storage)]
    AUTH[(Supabase Auth)]

    BUYER -->|email, password, name| AUTH
    SELLER -->|email, password, name| AUTH
    AUTH -->|session token| BUYER
    AUTH -->|session token| SELLER
    AUTH -->|trigger new user| DB

    SELLER -->|shop details| DB
    SELLER -->|logo, banner| STORAGE
    STORAGE -->|image URLs| DB
    SELLER -->|product info and images| DB
    SELLER -->|status updates| DB

    BUYER -->|browse, search, filter| DB
    DB -->|shops, products, categories| BUYER
    BUYER -->|add or remove cart items| DB
    BUYER -->|order and shipping info| DB
    DB -->|order confirmation| BUYER
    DB -->|order status updates| BUYER
    DB -->|trigger decrement stock| DB
    DB -->|order notifications| SELLER

    style BUYER fill:#FFF0F5,stroke:#E8849A,color:#4A3060
    style SELLER fill:#F3E8FF,stroke:#9B72CF,color:#4A3060
    style DB fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style STORAGE fill:#E8849A,stroke:#D06B80,color:#FFF
    style AUTH fill:#F59E0B,stroke:#D97706,color:#FFF
