flowchart TD
    START([User Visits Website]) --> BROWSE[Browse Home Page]
    BROWSE --> AUTH_CHECK{Authenticated?}

    AUTH_CHECK -->|No| PUBLIC_ACTIONS[View Shops / Products / Categories]
    AUTH_CHECK -->|No| AUTH_PROMPT[Login or Register]
    AUTH_CHECK -->|Yes| ROLE_CHECK{User Role?}

    PUBLIC_ACTIONS --> VIEW_PRODUCT[View Product Details]
    VIEW_PRODUCT --> AUTH_PROMPT

    AUTH_PROMPT --> REGISTER[Register Account]
    AUTH_PROMPT --> LOGIN[Login]

    REGISTER --> CHOOSE_ROLE{Choose Role}
    CHOOSE_ROLE -->|Buyer| CREATE_BUYER[Create Buyer Profile]
    CHOOSE_ROLE -->|Seller| CREATE_SELLER[Create Seller Profile]
    CREATE_BUYER --> VERIFY_EMAIL[Verify Email]
    CREATE_SELLER --> VERIFY_EMAIL
    VERIFY_EMAIL --> LOGIN

    LOGIN --> ROLE_CHECK

    ROLE_CHECK -->|Buyer| BUYER_FLOW[Buyer Dashboard]
    ROLE_CHECK -->|Seller| SELLER_FLOW[Seller Dashboard]

    BUYER_FLOW --> B_BROWSE[Browse Shops and Products]
    B_BROWSE --> B_VIEW[View Product Details]
    B_VIEW --> B_ADD_CART[Add to Cart]
    B_ADD_CART --> B_CONTINUE{Continue Shopping?}
    B_CONTINUE -->|Yes| B_BROWSE
    B_CONTINUE -->|No| B_CHECKOUT[Proceed to Checkout]
    B_CHECKOUT --> B_FILL_SHIPPING[Fill Shipping Details]
    B_FILL_SHIPPING --> B_PLACE_ORDER[Place Order]
    B_PLACE_ORDER --> B_CONFIRMATION[Order Confirmation]
    B_CONFIRMATION --> B_TRACK[Track Order Status]
    BUYER_FLOW --> B_MY_ORDERS[View My Orders]
    B_MY_ORDERS --> B_ORDER_DETAIL[View Order Details]

    SELLER_FLOW --> S_HAS_SHOP{Has Shop?}
    S_HAS_SHOP -->|No| S_CREATE_SHOP[Create Shop]
    S_CREATE_SHOP --> S_SETUP[Upload Logo and Banner]
    S_SETUP --> S_DASHBOARD[Shop Dashboard]
    S_HAS_SHOP -->|Yes| S_DASHBOARD

    S_DASHBOARD --> S_ADD_PRODUCT[Add Product]
    S_DASHBOARD --> S_MANAGE_PRODUCTS[Manage Products]
    S_DASHBOARD --> S_VIEW_ORDERS[View Incoming Orders]
    S_DASHBOARD --> S_SHOP_SETTINGS[Edit Shop Settings]

    S_ADD_PRODUCT --> S_FILL_PRODUCT[Fill Name, Price, Stock, Images]
    S_FILL_PRODUCT --> S_SAVE_PRODUCT[Save Product]
    S_SAVE_PRODUCT --> S_DASHBOARD

    S_MANAGE_PRODUCTS --> S_EDIT[Edit Product]
    S_MANAGE_PRODUCTS --> S_DELETE[Delete Product]

    S_VIEW_ORDERS --> S_ORDER_DETAIL[View Order Details]
    S_ORDER_DETAIL --> S_UPDATE_STATUS[Update Order Status]
    S_UPDATE_STATUS --> S_STATUS_FLOW[Pending then Confirmed then Shipped then Delivered]

    style START fill:#F3E8FF,stroke:#9B72CF,color:#4A3060
    style BUYER_FLOW fill:#FFF0F5,stroke:#E8849A,color:#4A3060
    style SELLER_FLOW fill:#F3E8FF,stroke:#9B72CF,color:#4A3060
    style B_PLACE_ORDER fill:#E8849A,stroke:#D06B80,color:#FFF
    style B_CONFIRMATION fill:#BBF7D0,stroke:#4ADE80,color:#1A1A1A
    style VERIFY_EMAIL fill:#FEF3C7,stroke:#F59E0B,color:#1A1A1A
