flowchart TD
    A([Buyer Views Cart]) --> B{Cart Empty?}
    B -->|Yes| C[Show Empty Cart Message]
    B -->|No| D[Click Checkout]

    D --> E[Fill Shipping Address and Phone]
    E --> F[Review Order Summary]
    F --> G[Click Place Order]

    G --> H[Calculate Subtotal + Shipping]
    H --> I[INSERT into orders table]
    I --> J[DB Trigger generate_order_number]
    J --> K[Order Number ORD-XXXXXXXX]

    K --> L[For Each Cart Item]
    L --> M[INSERT into order_items]
    M --> N[Snapshot product_name, unit_price, product_image]

    N --> O[DB Trigger decrement_stock_on_order]
    O --> P[UPDATE products stock = greatest of stock minus qty or 0]

    N --> Q[RPC Backup decrement_product_stock]
    Q --> P

    P --> R[Clear Cart Items from DB]
    R --> S[Redirect to Order Confirmation]
    S --> T([Order Complete - Status Pending])

    style G fill:#E8849A,stroke:#D06B80,color:#FFF
    style I fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style M fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style O fill:#F59E0B,stroke:#D97706,color:#FFF
    style Q fill:#F59E0B,stroke:#D97706,color:#FFF
    style T fill:#BBF7D0,stroke:#4ADE80,color:#1A1A1A
