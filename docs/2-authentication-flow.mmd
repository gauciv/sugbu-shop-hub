flowchart TD
    A([User]) --> B{Has Account?}
    B -->|No| C[Register Page]
    B -->|Yes| D[Login Page]

    C --> E[Enter Email, Password, Name]
    E --> F{Choose Role}
    F -->|Buyer| G[role = buyer]
    F -->|Seller| H[role = seller]
    G --> I[Supabase Auth signUp]
    H --> I

    I --> J[DB Trigger handle_new_user]
    J --> K[Auto-Create Profile Row]
    K --> L[Redirect to Verify Email Page]
    L --> M[User Checks Email Inbox]
    M --> N[Click Verification Link]
    N --> O[Email Confirmed Page]
    O --> D

    D --> P[Enter Email and Password]
    P --> Q[Supabase Auth signIn]
    Q --> R{Success?}
    R -->|No| S[Show Error Message]
    S --> D
    R -->|Yes| T[Load Profile from DB]
    T --> U{role?}
    U -->|buyer| V[Redirect to Home Page]
    U -->|seller| W[Redirect to Seller Dashboard]

    style I fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style J fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style K fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style N fill:#BBF7D0,stroke:#4ADE80,color:#1A1A1A
