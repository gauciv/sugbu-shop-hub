erDiagram
    AUTH_USERS {
        uuid id PK
        text email
        text encrypted_password
        timestamptz created_at
        timestamptz updated_at
    }

    PROFILES {
        uuid id PK, FK
        text email
        text full_name
        text avatar_url
        text role "buyer | seller"
        text phone
        timestamptz created_at
        timestamptz updated_at
    }

    SHOPS {
        uuid id PK
        uuid owner_id FK, UK "one shop per seller"
        text name
        text slug UK
        text description
        text logo_url
        text banner_url
        text contact_email
        text contact_phone
        text address
        boolean is_active "default true"
        timestamptz created_at
        timestamptz updated_at
    }

    CATEGORIES {
        uuid id PK
        text name UK
        text slug UK
        text icon
        int display_order "default 0"
        timestamptz created_at
    }

    PRODUCTS {
        uuid id PK
        uuid shop_id FK
        uuid category_id FK "nullable"
        text name
        text description
        numeric price "precision 10,2"
        numeric compare_at_price "nullable, original price"
        int stock "default 0, decremented by trigger"
        text_array image_urls "default empty"
        boolean is_active "default true"
        timestamptz created_at
        timestamptz updated_at
    }

    CART_ITEMS {
        uuid id PK
        uuid user_id FK
        uuid product_id FK
        int quantity "default 1"
        timestamptz created_at
    }

    ORDERS {
        uuid id PK
        text order_number UK "auto ORD-XXXXXXXX"
        uuid buyer_id FK
        uuid shop_id FK
        text status "pending|confirmed|preparing|shipped|delivered|cancelled"
        numeric subtotal "precision 10,2"
        numeric shipping_fee "precision 10,2"
        numeric total "precision 10,2"
        text shipping_address
        text contact_phone
        text notes
        timestamptz created_at
        timestamptz updated_at
    }

    ORDER_ITEMS {
        uuid id PK
        uuid order_id FK
        uuid product_id FK
        text product_name "denormalized snapshot"
        text product_image "denormalized snapshot"
        numeric unit_price "precision 10,2"
        int quantity
        numeric line_total "unit_price x quantity"
    }

    AUTH_USERS ||--|| PROFILES : "creates via trigger"
    PROFILES ||--o| SHOPS : "owns (seller only)"
    PROFILES ||--o{ CART_ITEMS : "has"
    PROFILES ||--o{ ORDERS : "places as buyer"
    SHOPS ||--o{ PRODUCTS : "lists"
    SHOPS ||--o{ ORDERS : "receives"
    CATEGORIES ||--o{ PRODUCTS : "classifies"
    PRODUCTS ||--o{ CART_ITEMS : "added to"
    PRODUCTS ||--o{ ORDER_ITEMS : "ordered as"
    ORDERS ||--|{ ORDER_ITEMS : "contains"
