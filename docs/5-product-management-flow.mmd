flowchart TD
    A([Seller Dashboard]) --> B[Products Page]
    B --> C{Action?}

    C -->|Add New| D[Product Form]
    D --> E[Fill Name, Description, Price, Stock, Category]
    E --> F[Upload Product Images]
    F --> G[Supabase Storage product-images bucket]
    G --> H[Get Image URLs]
    H --> I[INSERT into products table]
    I --> J[Product Live on Store]

    C -->|Edit| K[Load Existing Product]
    K --> L[Modify Fields]
    L --> M[UPDATE products table]
    M --> J

    C -->|Delete| N[Confirm Deletion]
    N --> O[DELETE from products]
    O --> P[CASCADE Remove from all carts]

    C -->|Toggle| Q[Set is_active true or false]
    Q --> R[Product Hidden or Shown on Store]

    style D fill:#F3E8FF,stroke:#9B72CF,color:#4A3060
    style G fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style I fill:#9B72CF,stroke:#7C5AAF,color:#FFF
    style J fill:#BBF7D0,stroke:#4ADE80,color:#1A1A1A
    style P fill:#FECACA,stroke:#EF4444,color:#1A1A1A
